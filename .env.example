# Database
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=e2d_practice_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/e2d_practice_db

# JWT
JWT_SECRET=supersecret_key_for_development_only
JWT_EXPIRES_IN=1d

# API
API_PORT=3001

# Email (Mailhog — set to smtp.ethereal.email for cloud testing)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASS=

# Frontend URL (used in magic link emails)
FRONTEND_URL=http://localhost:5173

# AI provider: mock | ollama | openai
# When running via Docker, use host.docker.internal instead of localhost to reach host services:
#   AI_BASE_URL=http://host.docker.internal:11434  (Docker)
#   AI_BASE_URL=http://localhost:11434             (local dev without Docker)
AI_PROVIDER=mock
AI_BASE_URL=http://localhost:11434
AI_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=
